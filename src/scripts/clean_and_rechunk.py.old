#!/usr/bin/env python3
"""
Clean and Rechunk - Medical PDF Node Processor (v3)
====================================================

Pipeline: Cleaning V1 -> Final Cleaning (table placeholder) -> Chunking -> Audit

Features:
1) CLEAN NOISE: Remove image links, footer logs, gibberish OCR
2) FINAL CLEAN: Fix Vietnamese text, normalize headers/bullets, extract tables to placeholders
3) CHUNK: Semantic chunking by heading/paragraph, table atomic
4) AUDIT: Detect noise, duplicates, table issues, generate reports

Configuration:
- ENABLE_HEAVY_TABLE_REPAIR = False (tables dropped via placeholder, not rebuilt)
- tools/clean_and_repair_nodes.py and tools/rechunk_by_structure.py are OPTIONAL

Output:
- Final JSON -> processed/
- Intermediate -> temp_pipeline/
- Reports -> temp_pipeline/reports/

Usage:
    python scripts/clean_and_rechunk.py data/processed/ --output data/processed/
    python scripts/clean_and_rechunk.py data/processed/ --dry-run
    python scripts/clean_and_rechunk.py data/processed/ --target-chars 8000
"""

import re
import json
import argparse
import logging
import shutil
from pathlib import Path
from dataclasses import dataclass, field
from typing import Any, cast, Dict, List
from collections import defaultdict

# Import pipeline modules
import sys
sys.path.insert(0, str(Path(__file__).parent.parent))

from pipeline.cleaning_v1 import clean_marker_output
from pipeline.final_cleaning import final_clean_content
from pipeline.chunking import chunk_to_nodes, estimate_tokens
from pipeline.audit_nodes import audit_and_merge_nodes, generate_audit_report

logging.basicConfig(level=logging.INFO, format='%(levelname)s: %(message)s')
logger = logging.getLogger(__name__)


# =============================================================================
# CONFIGURATION
# =============================================================================

# Heavy table repair is DISABLED by default (Option A: placeholder)
ENABLE_HEAVY_TABLE_REPAIR = False

# Default paths
DEFAULT_TEMP_DIR = Path("temp_pipeline")
DEFAULT_PROCESSED_DIR = Path("data/processed")


# =============================================================================
# DATA CLASSES
# =============================================================================

@dataclass
class PipelineStats:
    """Statistics for pipeline operations"""
    total_files: int = 0
    total_input_nodes: int = 0
    image_links_removed: int = 0
    footer_lines_removed: int = 0
    tables_removed: int = 0
    high_risk_tables: int = 0
    headers_normalized: int = 0
    output_nodes: int = 0
    output_chunks: int = 0
    noise_detected: int = 0
    duplicates_found: int = 0
    skipped_admin: int = 0
    skipped_toc: int = 0


def _empty_list() -> list[str]:
    return []


# =============================================================================
# CONTENT CLASSIFICATION
# =============================================================================

ADMIN_KEYWORDS = [
    'Căn cứ', 'QUYẾT ĐỊNH', 'Nơi nhận', 'KT. BỘ TRƯỞNG',
    'Kính gửi', 'Số ký hiệu', 'Ngày ký', 'Chứng thực',
    'Xác nhận', 'Ký duyệt', 'THỨ TRƯỞNG', 'CỘNG HÒA XÃ HỘI',
    'Độc lập - Tự do', 'BỘ Y TẾ',
]


def is_administrative(content: str) -> bool:
    """Detect administrative / legal preamble content."""
    content_lower = content.lower()
    hits = sum(1 for kw in ADMIN_KEYWORDS if kw.lower() in content_lower)
    return hits >= 3


def is_toc(content: str) -> bool:
    """Detect table-of-contents blocks."""
    if 'MỤC LỤC' in content.upper():
        return True
    lines = [l for l in content.split('\n') if l.strip()]
    if not lines:
        return False
    dot_lines = sum(1 for l in lines if re.search(r'\.{3,}', l))
    page_ref = sum(1 for l in lines
                   if re.search(r'\.{3,}\s*\d+\s*$', l.strip()))
    return dot_lines > 3 and page_ref / max(len(lines), 1) > 0.3


# =============================================================================
# RECHUNKING FUNCTIONS (preserved from original)
# =============================================================================

def find_section_boundaries(content: str) -> list[tuple[int, str, int]]:
    """Find section boundaries: (char_index, title, level)."""
    boundaries: list[tuple[int, str, int]] = []
    lines = content.split('\n')
    char_pos = 0

    for line in lines:
        stripped = line.strip()
        level: int | None = None
        title: str | None = None

        # Markdown headers
        m = re.match(r'^(#{1,6})\s+(.+)$', stripped)
        if m:
            level = len(m.group(1))
            title = m.group(2)

        # Numbered sections: 1. / 1.1 / 1.1.1
        if level is None:
            m = re.match(r'^(\d+(?:\.\d+)*\.?)\s+(.+)$', stripped)
            if m:
                level = m.group(1).count('.') + 1
                title = f"{m.group(1)} {m.group(2)}"

        # Vietnamese section markers
        if level is None:
            m = re.match(r'^(CHƯƠNG|MỤC|PHẦN)\s+(.+)$',
                         stripped, re.IGNORECASE)
            if m:
                level = 1
                title = f"{m.group(1)} {m.group(2)}"

        if level is not None and title is not None:
            boundaries.append((char_pos, title, level))

        char_pos += len(line) + 1

    return boundaries


def _safe_break_position(
    content: str,
    current_start: int,
    target_end: int,
    max_end: int,
    boundaries: list[tuple[int, str, int]],
    min_chars: int,
) -> int:
    """Find the best safe break position at a section boundary or blank line."""
    content_len = len(content)

    # Candidate 1: section boundaries between min_chars and max_end
    best: int | None = None
    for pos, _title, _level in boundaries:
        if current_start + min_chars <= pos <= max_end:
            if best is None or abs(pos - target_end) < abs(best - target_end):
                best = pos
    if best is not None:
        return best

    # Candidate 2: double-newline after target_end
    search_start = max(target_end - 200, current_start + min_chars)
    idx = search_start
    while idx < max_end:
        pos = content.find('\n\n', idx)
        if pos == -1 or pos >= max_end:
            break
        return pos + 2
    
    # Candidate 3: any newline position
    for pos in range(target_end, max_end):
        if content[pos] == '\n':
            return pos + 1

    return min(max_end, content_len)


def rechunk_by_structure(
    nodes: list[dict[str, Any]],
    target_chars: int = 8000,
    min_chars: int = 2000,
    max_chars: int = 0,
    stats: PipelineStats | None = None,
) -> list[dict[str, Any]]:
    """Rechunk nodes by document structure.

    - Groups by source document.
    - Splits only at safe boundaries (heading, blank line pair).
    - Allows chunk to grow up to max_chars before forced cut.
    """
    if max_chars <= 0:
        max_chars = int(target_chars * 1.8)

    if not nodes:
        return []

    # Group by source
    by_source: dict[str, list[dict[str, Any]]] = defaultdict(list)
    for node in nodes:
        source = node.get('source', node.get('metadata', {}).get('doc_id', 'unknown'))
        by_source[source].append(node)

    output_chunks: list[dict[str, Any]] = []

    for source, source_nodes in by_source.items():
        source_nodes.sort(key=lambda n: (n.get('page', 0), n.get('id', '')))

        # --- Merge all content ---
        merged_content = ''
        page_markers: list[tuple[int, int]] = []

        for node in source_nodes:
            page = node.get('page', node.get('metadata', {}).get('node_index', 0))
            content = node.get('content', '')
            if merged_content:
                merged_content += '\n\n'
            page_markers.append((len(merged_content), page))
            merged_content += content

        if not merged_content.strip():
            continue

        # Clean page markers
        merged_content = re.sub(r'<!--PAGE:\d+-->\s*', '', merged_content)

        # --- Analysis ---
        boundaries = find_section_boundaries(merged_content)
        content_length = len(merged_content)

        # --- Build chunks ---
        current_start = 0
        chunk_idx = 0

        while current_start < content_length:
            target_end = min(current_start + target_chars, content_length)
            max_end = min(current_start + max_chars, content_length)

            if target_end >= content_length:
                break_pos = content_length
            else:
                break_pos = _safe_break_position(
                    merged_content, current_start, target_end, max_end,
                    boundaries, min_chars,
                )

            chunk_content = merged_content[current_start:break_pos].strip()

            if chunk_content:
                # Page range
                chunk_page = _page_at(current_start, page_markers)

                # Section path
                section_path = 'Document'
                for pos, title, _level in boundaries:
                    if pos <= current_start:
                        section_path = title[:60]

                chunk_id = f"{Path(source).stem}_chunk_{chunk_idx:04d}"

                new_chunk: dict[str, Any] = {
                    'source': source,
                    'page': chunk_page if chunk_page > 0 else 1,
                    'chunk_id': chunk_id,
                    'section_path': section_path,
                    'tags': source_nodes[0].get('tags', []) if source_nodes else [],
                    'content': chunk_content,
                    'metadata': {
                        'char_count': len(chunk_content),
                        'token_count': estimate_tokens(chunk_content),
                    },
                }
                output_chunks.append(new_chunk)
                chunk_idx += 1

            if break_pos <= current_start:
                break_pos = current_start + max_chars
            current_start = break_pos

        if stats:
            stats.output_chunks += chunk_idx

    return output_chunks


def _page_at(char_pos: int, page_markers: list[tuple[int, int]]) -> int:
    """Get page number at character position."""
    page = 1
    for mpos, pnum in page_markers:
        if mpos <= char_pos:
            if pnum > 0:
                page = pnum
        else:
            break
    return page


# =============================================================================
# CLEANING FUNCTIONS
# =============================================================================

def remove_image_links(content: str, stats: CleaningStats) -> str:
    """Remove local image links like ![](*.jpeg), including '![](...  . jpeg)' with space."""
    # Single unified pattern: ![...](...) where path ends with image extension
    # Handles optional spaces before extension
    pattern = r'!\[[^\]]*\]\([^)]*\.\s*(?:jpe?g|png|gif|bmp)\s*\)'
    matches = re.findall(pattern, content, re.IGNORECASE)
    stats.image_links_removed += len(matches)
    content = re.sub(pattern, '', content, flags=re.IGNORECASE)
    # Clean up leftover blank lines
    content = re.sub(r'\n{3,}', '\n\n', content)
    return content


def remove_footer_lines(content: str, stats: CleaningStats) -> str:
    """Remove footer/system log lines: kcb_...dd/mm/yyyy  hh : mm : ss"""
    lines = content.split('\n')
    cleaned_lines: list[str] = []

    footer_patterns = [
        # kcb_ with date (spaces allowed around separators)
        r'kcb[_.].*\d{1,2}\s*/\s*\d{1,2}\s*/\s*\d{4}',
        # kcb_ with time (spaces allowed around colons)
        r'kcb[_.].*\d{1,2}\s*:\s*\d{2}\s*:\s*\d{2}',
        # generic kcb line with 10+ chars junk
        r'^[*\s]*kcb[_.][^\n]{10,}$',
        r'<PARSED TEXT',
        r'\[Page\s*\d+\]',
        r'---Page Break---',
    ]

    for line in lines:
        is_footer = False
        for pat in footer_patterns:
            if re.search(pat, line, re.IGNORECASE):
                is_footer = True
                stats.footer_lines_removed += 1
                break
        if not is_footer:
            cleaned_lines.append(line)

    return '\n'.join(cleaned_lines)


def remove_long_separators(content: str, stats: CleaningStats) -> str:
    """Remove separator lines of dashes/em-dashes > 50 chars."""
    lines = content.split('\n')
    cleaned: list[str] = []
    for line in lines:
        stripped = line.strip()
        if re.match(r'^[-—_=~]{50,}$', stripped):
            stats.long_separators_removed += 1
            continue
        cleaned.append(line)
    return '\n'.join(cleaned)


def remove_spam_lines(content: str, stats: CleaningStats) -> str:
    """Remove spam / repetitive lines.

    Rules:
    - Single token repeated >= 30 times → drop
    - Bigram (e.g. '200 A') repeated >= 20 times → drop
    - Only 1-3 unique tokens but 10+ total → drop
    """
    lines = content.split('\n')
    cleaned_lines: list[str] = []

    for line in lines:
        stripped = line.strip()
        if not stripped:
            cleaned_lines.append(line)
            continue

        tokens = stripped.split()
        if len(tokens) < 4:
            cleaned_lines.append(line)
            continue

        # Rule 1: single token repeated >= 30 times
        token_counts: dict[str, int] = defaultdict(int)
        for t in tokens:
            token_counts[t] += 1
        if max(token_counts.values()) >= 30:
            stats.spam_lines_removed += 1
            continue

        # Rule 2: bigram repeated >= 20 times
        if len(tokens) >= 6:
            bigram_counts: dict[str, int] = defaultdict(int)
            for i in range(len(tokens) - 1):
                bg = f"{tokens[i]} {tokens[i+1]}"
                bigram_counts[bg] += 1
            if bigram_counts and max(bigram_counts.values()) >= 20:
                stats.spam_lines_removed += 1
                continue

        # Rule 3: very few unique tokens but many total
        if len(set(tokens)) <= 3 and len(tokens) > 10:
            stats.spam_lines_removed += 1
            continue

        cleaned_lines.append(line)

    return '\n'.join(cleaned_lines)


def remove_gibberish_lines(content: str, stats: CleaningStats) -> str:
    """Remove gibberish OCR lines: low valid-char ratio on long lines."""
    lines = content.split('\n')
    cleaned_lines: list[str] = []

    valid_pattern = re.compile(
        r'[a-zA-ZÀ-ỹ0-9\s\.\,\;\:\!\?\-\(\)\[\]\{\}\|'
        r'\+\=\*\/\#\@\%\&\"\'\`\~\<\>]'
    )

    gibberish_exact = [
        re.compile(r'deo da la la companya', re.IGNORECASE),
        re.compile(r'([^\s])\1{10,}'),  # same char repeated 10+ times
    ]

    for line in lines:
        stripped = line.strip()

        if len(stripped) <= 120:
            cleaned_lines.append(line)
            continue

        # Valid-char ratio
        valid_chars = len(valid_pattern.findall(stripped))
        ratio = valid_chars / len(stripped) if stripped else 1.0
        if ratio < 0.6:
            stats.gibberish_lines_removed += 1
            continue

        # Exact gibberish patterns
        is_gib = False
        for pat in gibberish_exact:
            if pat.search(stripped):
                is_gib = True
                stats.gibberish_lines_removed += 1
                break
        if is_gib:
            continue

        cleaned_lines.append(line)

    return '\n'.join(cleaned_lines)


# =============================================================================
# TABLE REPAIR — State Machine
# =============================================================================

def _count_pipes(line: str) -> int:
    return line.count('|')


def _is_table_line(line: str) -> bool:
    """Line that looks like part of a markdown table."""
    stripped = line.strip()
    return '|' in stripped and _count_pipes(stripped) >= 2


def _is_separator_row(line: str) -> bool:
    """Check if line is a table separator like |---|---|"""
    stripped = line.strip()
    if not stripped.startswith('|'):
        return False
    cells = stripped.split('|')
    dash_cells = sum(1 for c in cells if c.strip() and set(c.strip()) <= {'-', ':', ' '})
    return dash_cells >= 2


def detect_table_blocks(content: str) -> list[TableBlock]:
    """Detect table blocks using a state machine.

    in_table = True when recent lines (window of 3) have >= 2 lines with '|'
                and total '|' count >= 4.
    in_table = False when 2 consecutive non-pipe lines or heading '#' encountered.
    Peek ahead before exiting: if next 1-2 lines have pipes, continue table.
    """
    lines = content.split('\n')
    blocks: list[TableBlock] = []

    in_table = False
    block_start = 0
    block_lines: list[str] = []
    consecutive_no_pipe = 0

    for i, line in enumerate(lines):
        stripped = line.strip()
        # When already inside a table, be lenient: any '|' counts
        if in_table:
            has_pipe = '|' in stripped
        else:
            has_pipe = '|' in stripped and _count_pipes(stripped) >= 2
        is_heading = stripped.startswith('#') and not stripped.startswith('#|')

        if not in_table:
            if has_pipe:
                # Look at window of 3 lines to decide if table starts
                window = lines[max(0, i):min(len(lines), i + 3)]
                pipe_lines = sum(1 for w in window if '|' in w and _count_pipes(w) >= 2)
                total_pipes = sum(_count_pipes(w) for w in window)
                if pipe_lines >= 2 and total_pipes >= 4:
                    in_table = True
                    block_start = i
                    block_lines = [line]
                    consecutive_no_pipe = 0
            # else: not a table line, skip
        else:
            # Currently in table
            if is_heading:
                # Heading ends table
                _finalize_table_block(blocks, block_start, i - 1, block_lines)
                in_table = False
                block_lines = []
                consecutive_no_pipe = 0
            elif has_pipe:
                block_lines.append(line)
                consecutive_no_pipe = 0
            elif stripped == '':
                # Empty line: tentatively end table, but peek ahead first
                consecutive_no_pipe += 1
                if consecutive_no_pipe >= 2:
                    # Peek ahead: check next 5 lines for pipes (covers cross-node gaps)
                    peek_found_pipe = False
                    for peek_offset in range(1, min(6, len(lines) - i)):
                        peek_line = lines[i + peek_offset].strip()
                        if '|' in peek_line:
                            peek_found_pipe = True
                            break
                    
                    if peek_found_pipe:
                        # Continue table - treat blank lines as part of table
                        block_lines.append(line)
                        # Reset consecutive counter (will increment again on next blank)
                        consecutive_no_pipe = 1
                    else:
                        # No pipes ahead - truly end table
                        _finalize_table_block(blocks, block_start,
                                              i - consecutive_no_pipe, block_lines)
                        in_table = False
                        block_lines = []
                        consecutive_no_pipe = 0
                else:
                    block_lines.append(line)
            else:
                # Non-pipe, non-empty: could be continuation line
                consecutive_no_pipe += 1
                if consecutive_no_pipe >= 2:
                    _finalize_table_block(blocks, block_start,
                                          i - consecutive_no_pipe, block_lines)
                    in_table = False
                    block_lines = []
                    consecutive_no_pipe = 0
                else:
                    block_lines.append(line)

    # Finalize if still in table at EOF
    if in_table and block_lines:
        _finalize_table_block(blocks, block_start, len(lines) - 1, block_lines)

    return blocks


def _finalize_table_block(
    blocks: list[TableBlock], start: int, end: int, lines: list[str]
) -> None:
    """Add a table block if it has enough pipe-lines."""
    pipe_count = sum(1 for l in lines if '|' in l)
    if pipe_count >= 2:
        block = TableBlock(start_line=start, end_line=end, lines=list(lines))
        # Detect column count from first row starting with |
        for bl in lines:
            stripped = bl.strip()
            if stripped.startswith('|') and stripped.endswith('|') and not _is_separator_row(stripped):
                block.column_count = max(stripped.count('|') - 1, 1)
                break
        if block.column_count == 0:
            # Fallback: count from first pipe-line
            for bl in lines:
                if '|' in bl:
                    block.column_count = max(bl.count('|') - 1, 1)
                    break
        blocks.append(block)


def merge_orphaned_table_fragments(content: str, stats: CleaningStats) -> str:
    """Merge short orphaned lines into their preceding table row.

    OCR sometimes splits table cell content across multiple lines.
    These orphaned fragments are short lines without markdown markers
    that appear right after a line ending with | or containing |.
    Must run BEFORE table state machine detection.
    """
    lines = content.split('\n')
    result: list[str] = []

    for line in lines:
        stripped = line.strip()

        # Check if this is an orphaned fragment:
        # - Not empty
        # - Short (< 60 chars)
        # - Doesn't start with markdown markers (|, #, -, *, >, digit.)
        # - Previous non-empty line is a table row
        if (
            stripped
            and len(stripped) < 60
            and not stripped.startswith(('|', '#', '- ', '* ', '> '))
            and not re.match(r'^\d+\.\s', stripped)
            and result
        ):
            # Find most recent non-empty line
            target_idx = -1
            for i in range(len(result) - 1, max(len(result) - 3, -1), -1):
                if result[i].strip():
                    if result[i].strip().startswith('|'):
                        target_idx = i
                    break
            
            if target_idx >= 0:
                # Merge into that table row
                prev = result[target_idx].rstrip()
                if prev.endswith('|'):
                    # Insert before trailing pipe
                    result[target_idx] = prev[:-1].rstrip() + ' ' + stripped
                    if not result[target_idx].rstrip().endswith('|'):
                        result[target_idx] = result[target_idx].rstrip() + ' |'
                else:
                    result[target_idx] = prev + ' ' + stripped
                stats.continuation_lines_merged += 1
            else:
                result.append(line)
        else:
            result.append(line)

    return '\n'.join(result)


def merge_continuation_lines(table_lines: list[str], stats: CleaningStats) -> list[str]:
    """Merge continuation lines (not starting with |) into previous row."""
    if not table_lines:
        return table_lines

    merged: list[str] = []

    for line in table_lines:
        stripped = line.strip()

        if stripped.startswith('|'):
            merged.append(line)
        elif merged and stripped:
            # Continuation: merge into previous row
            stats.continuation_lines_merged += 1
            prev = merged[-1].rstrip()
            # If previous line ends with |, insert before it
            if prev.endswith('|'):
                merged[-1] = prev[:-1].rstrip() + ' ' + stripped
                if not merged[-1].rstrip().endswith('|'):
                    merged[-1] = merged[-1].rstrip() + ' |'
            else:
                merged[-1] = prev + ' ' + stripped
        else:
            merged.append(line)

    return merged


def fix_separator_row(row: str, column_count: int, stats: CleaningStats) -> str:
    """Rebuild separator row to |---|---|...| with correct column count."""
    stripped = row.strip()
    if not _is_separator_row(stripped):
        return row
    stats.separator_rows_fixed += 1
    return '|' + '|'.join(['---'] * max(column_count, 1)) + '|'


def normalize_table_row(row: str) -> str:
    """Ensure row starts and ends with |."""
    stripped = row.strip()
    if not stripped:
        return row
    # Fix double pipes
    while '||' in stripped:
        stripped = stripped.replace('||', '| |')
    if not stripped.startswith('|'):
        stripped = '|' + stripped
    if not stripped.endswith('|'):
        stripped = stripped + '|'
    return stripped


def clean_latex_in_table(row: str) -> str:
    """Remove/simplify latex expressions in table cells."""
    row = re.sub(r'\$([^$]*)\$', r'\1', row)
    row = re.sub(r'\\mathrm\{([^}]*)\}', r'\1', row)
    row = re.sub(r'\\mathbf\{([^}]*)\}', r'\1', row)
    row = re.sub(r'\\text\{([^}]*)\}', r'\1', row)
    return row


def normalize_table_numbers(row: str) -> str:
    """Normalize number formatting in table cells.
    
    Fixes OCR errors like:
    - "3. 5 mg" -> "3.5 mg"
    - "1. 5" -> "1.5"
    - "0, 357" -> "0,357" (keep Vietnamese decimal comma, remove space)
    - "88, 4" -> "88,4"
    """
    # Fix decimal point with space: "3. 5" -> "3.5"
    row = re.sub(r'(\d+)\.\s+(\d+)', r'\1.\2', row)
    
    # Fix comma with space (Vietnamese thousand separator or decimal): "88, 4" -> "88,4"
    row = re.sub(r'(\d+),\s+(\d+)', r'\1,\2', row)
    
    # Fix spaced patterns like "1 1 11" (OCR artifacts)
    # But be careful not to break valid content like "1 lần/ngày"
    # Only target obviously wrong patterns: digit space digit space digit
    row = re.sub(r'\|\s*(\d)\s+(\d)\s+(\d+)\s*\|', r'| \1\2\3 |', row)
    
    return row


def filter_junk_table_rows(repaired: list[str], column_count: int) -> list[str]:
    """Remove junk rows from table (STT rác, malformed rows).
    
    Removes rows with:
    - Invalid STT in first column: '.05', '50', '200', '5, 00', '£30 /'
    - Rows that appear to be OCR artifacts
    """
    filtered: list[str] = []
    junk_stt_patterns = [
        r'^\|\s*\.?\d{1,3}\s*,\s*\d+\s*\|',  # "5, 00", "0, 357"
        r'^\|\s*\.0\d+\s*\|',                 # ".05"
        r'^\|\s*£\d+\s*/?\s*\|',              # "£30 /"
    ]
    
    for row in repaired:
        stripped = row.strip()
        if not stripped.startswith('|'):
            filtered.append(row)
            continue
            
        # Check for separator row (always keep)
        if _is_separator_row(stripped):
            filtered.append(row)
            continue
        
        # Check for junk STT patterns
        is_junk = False
        for pattern in junk_stt_patterns:
            if re.match(pattern, stripped):
                is_junk = True
                break
        
        # Also check for standalone numbers in first column that look like junk
        # But preserve valid STT like |1|, |2|, |3|
        match = re.match(r'^\|\s*(\d+)\s*\|', stripped)
        if match:
            stt = int(match.group(1))
            # If STT is > 50 and row looks suspiciously short, might be junk
            # But we need more context - for now, just flag very obvious ones
            if stt >= 100 and len(stripped) < 30:
                is_junk = True
        
        if not is_junk:
            filtered.append(row)
    
    return filtered


def repair_table_block(block: TableBlock, stats: CleaningStats,
                       warnings: list[str]) -> list[str]:
    """Repair a single table block: merge, separator, normalize, latex, quality gate."""
    # Step 1: Merge continuation lines
    merged = merge_continuation_lines(block.lines, stats)

    # Step 2: Fix each row
    repaired: list[str] = []
    for row in merged:
        if '|' in row:
            row = fix_separator_row(row, block.column_count, stats)
            row = normalize_table_row(row)
            row = clean_latex_in_table(row)
            row = normalize_table_numbers(row)
        repaired.append(row)

    # Step 2b: Merge incomplete rows with next fragment
    # Handle cases like: row ends with "| 1.|" and next row is "|5 mg/kg..."
    merged_incomplete: list[str] = []
    i = 0
    while i < len(repaired):
        row = repaired[i]
        stripped = row.strip()
        
        # Check if this row is incomplete (ends with pipe + digits + dot)
        if (stripped.startswith('|') and 
            re.search(r'\|\s*\d+\.\s*\|?\s*$', stripped)):
            # Look ahead for next table row (skip blanks)
            found_next = False
            for j in range(i + 1, min(i + 5, len(repaired))):
                next_row = repaired[j].strip()
                if next_row.startswith('|') and not _is_separator_row(next_row):
                    # Merge: remove trailing pipe from current, append next content
                    current_clean = re.sub(r'\|\s*$', '', stripped)
                    merged_incomplete.append(current_clean + next_row)
                    # Skip next row (already merged)
                    i = j + 1
                    found_next = True
                    stats.continuation_lines_merged += 1
                    break
            if not found_next:
                merged_incomplete.append(row)
                i += 1
        else:
            merged_incomplete.append(row)
            i += 1
    
    repaired = merged_incomplete

    # Step 2c: Filter junk rows (STT rác)
    repaired = filter_junk_table_rows(repaired, block.column_count)

    stats.tables_repaired += 1

    # Step 3: Quality gate
    for row in repaired:
        stripped = row.strip()
        if not stripped or _is_separator_row(stripped):
            continue
        if stripped.startswith('|'):
            pipe_count = stripped.count('|')
            expected = block.column_count + 1
            if abs(pipe_count - expected) >= 1:
                msg = (f"TABLE WARNING (HIGH): row has {pipe_count} pipes, "
                       f"expected ~{expected}: {stripped[:80]}")
                warnings.append(msg)
                stats.high_warnings += 1

    return repaired


def repair_all_tables(content: str, stats: CleaningStats,
                      warnings: list[str] | None = None) -> str:
    """Repair all tables in content."""
    if warnings is None:
        warnings = []
    blocks = detect_table_blocks(content)
    if not blocks:
        return content

    lines = content.split('\n')

    # Process in reverse to maintain line indices
    for block in reversed(blocks):
        repaired_lines = repair_table_block(block, stats, warnings)
        lines[block.start_line:block.end_line + 1] = repaired_lines

    return '\n'.join(lines)


# =============================================================================
# STRUCTURE NORMALIZATION
# =============================================================================

def is_junk_separator(line: str) -> bool:
    """Check if line is a junk separator (------ or ====== > 20 chars)."""
    stripped = line.strip()
    if len(stripped) < 20:
        return False
    junk_chars = set('-=_~*')
    return bool(stripped) and all(c in junk_chars or c.isspace() for c in stripped)


def replace_br_in_tables(content: str, stats: CleaningStats) -> str:
    """Replace <br> / <br/> with space inside table rows, newline elsewhere."""
    lines = content.split('\n')
    result: list[str] = []
    for line in lines:
        if '<br' in line.lower():
            if '|' in line:
                # Inside table row: replace with space
                count = len(re.findall(r'<br\s*/?>', line, re.IGNORECASE))
                stats.br_replaced += count
                line = re.sub(r'<br\s*/?>', ' ', line, flags=re.IGNORECASE)
            else:
                count = len(re.findall(r'<br\s*/?>', line, re.IGNORECASE))
                stats.br_replaced += count
                line = re.sub(r'<br\s*/?>', '\n', line, flags=re.IGNORECASE)
        result.append(line)
    return '\n'.join(result)


def normalize_headers(content: str, stats: CleaningStats) -> str:
    """Fix headers: '## - ...' → '## ...', ensure blank line before headings."""
    lines = content.split('\n')
    normalized: list[str] = []

    for line in lines:
        stripped = line.strip()

        # Fix "## - text" and "#### - text" patterns
        match_hdr_dash = re.match(r'^(#{1,6})\s*-\s+(.*)$', stripped)
        if match_hdr_dash:
            line = f"{match_hdr_dash.group(1)} {match_hdr_dash.group(2)}"
            stats.headers_normalized += 1

        # Ensure blank line before heading
        if re.match(r'^#{1,6}\s+', line.strip()):
            if normalized and normalized[-1].strip():
                normalized.append('')
                stats.headers_normalized += 1

        normalized.append(line)

    return '\n'.join(normalized)


def normalize_bullets(content: str) -> str:
    """Normalize bullets: '- +' → '  - ', ensure space after dash."""
    # Fix '- +' mid-line: split to new line before normalizing
    content = re.sub(r'\.\s*- \+\s*', '.\n  - ', content)
    # Fix '- +' at start of line → sub-item "  - "
    content = re.sub(r'^(\s*)- \+\s*', r'\1  - ', content, flags=re.MULTILINE)
    # Ensure space after bare dash bullet
    content = re.sub(r'^(\s*)-([^\s\-])', r'\1- \2', content, flags=re.MULTILINE)
    return content


def remove_junk_separators(content: str, stats: CleaningStats) -> str:
    """Remove junk separator lines."""
    lines = content.split('\n')
    cleaned: list[str] = []
    for line in lines:
        if is_junk_separator(line):
            stats.junk_separators_removed += 1
            continue
        cleaned.append(line)
    return '\n'.join(cleaned)


def clean_excessive_newlines(content: str) -> str:
    """Collapse 4+ consecutive newlines to 2."""
    while '\n\n\n\n' in content:
        content = content.replace('\n\n\n\n', '\n\n\n')
    return content


def deduplicate_consecutive_lines(content: str) -> str:
    """Remove consecutive duplicate lines or near-duplicate content.
    
    Handles cases like:
    - Same line repeated 2-3 times in a row
    - Overlapping fragments where line N+1 starts with end of line N
    - Footnote duplicating table cell content (e.g., <sup>*</sup>Text... when Text is in table above)
    """
    lines = content.split('\n')
    deduped: list[str] = []
    
    for line in lines:
        # Skip if this exact line was just added
        if deduped and line.strip() == deduped[-1].strip() and len(line.strip()) > 20:
            continue
        
        # Check for content duplication across table/non-table boundary
        # If current line (non-table) has substantial overlap with recent table cell
        curr_stripped = line.strip()
        is_table_row = curr_stripped.startswith('|') and '|' in curr_stripped[1:]
        
        if not is_table_row and len(curr_stripped) > 40 and deduped:
            # Remove HTML/markdown tags to get pure text for comparison
            import re
            curr_clean = re.sub(r'<[^>]+>|\*\*|__', '', curr_stripped)
            
            # Check last 2 lines for substantial text overlap
            found_duplicate = False
            for prev_line in deduped[-2:]:
                prev_clean = re.sub(r'<[^>]+>|\*\*|__|^\||\|$', '', prev_line.strip())
                
                # If current clean text is mostly contained in previous line
                # (e.g., footnote repeating table cell content)
                if len(curr_clean) > 40 and curr_clean in prev_clean:
                    found_duplicate = True
                    break
                # Or if they share a long common substring (>40 chars)
                for sub_len in range(min(len(curr_clean), len(prev_clean)), 40, -1):
                    for i in range(len(curr_clean) - sub_len + 1):
                        substring = curr_clean[i:i + sub_len]
                        if substring in prev_clean:
                            found_duplicate = True
                            break
                    if found_duplicate:
                        break
            
            if found_duplicate:
                continue
        
        # Check for overlap: if current line is a substring continuation of previous
        # Example: line[-1] = "...text ABC", line = "ABC more text"
        if deduped and len(line.strip()) > 20 and len(deduped[-1].strip()) > 20:
            prev = deduped[-1].strip()
            curr = line.strip()
            
            # Check if curr starts with the end of prev (overlap indicator)
            # Look for common suffix of prev matching prefix of curr
            for overlap_len in range(min(len(prev), len(curr), 100), 10, -1):
                if prev[-overlap_len:] == curr[:overlap_len]:
                    # Found overlap - merge by taking prev + non-overlapping part of curr
                    deduped[-1] = prev + ' ' + curr[overlap_len:]
                    break
            else:
                deduped.append(line)
        else:
            deduped.append(line)
    
    return '\n'.join(deduped)


# =============================================================================
# RECHUNKING FUNCTIONS
# =============================================================================

def find_section_boundaries(content: str) -> list[tuple[int, str, int]]:
    """Find section boundaries: (char_index, title, level)."""
    boundaries: list[tuple[int, str, int]] = []
    lines = content.split('\n')
    char_pos = 0

    for line in lines:
        stripped = line.strip()
        level: int | None = None
        title: str | None = None

        # Markdown headers
        m = re.match(r'^(#{1,6})\s+(.+)$', stripped)
        if m:
            level = len(m.group(1))
            title = m.group(2)

        # Numbered sections: 1. / 1.1 / 1.1.1
        if level is None:
            m = re.match(r'^(\d+(?:\.\d+)*\.?)\s+(.+)$', stripped)
            if m:
                level = m.group(1).count('.') + 1
                title = f"{m.group(1)} {m.group(2)}"

        # Roman numerals
        if level is None:
            m = re.match(r'^(I{1,3}|IV|V|VI{0,3}|IX|X{0,3})\.\s+(.+)$',
                         stripped, re.IGNORECASE)
            if m:
                level = 1
                title = f"{m.group(1)}. {m.group(2)}"

        # Vietnamese section markers
        if level is None:
            m = re.match(r'^(CHƯƠNG|MỤC|PHẦN)\s+(.+)$',
                         stripped, re.IGNORECASE)
            if m:
                level = 1
                title = f"{m.group(1)} {m.group(2)}"

        if level is not None and title is not None:
            boundaries.append((char_pos, title, level))

        char_pos += len(line) + 1

    return boundaries


def find_table_ranges(content: str) -> list[tuple[int, int]]:
    """Find character ranges of table blocks for boundary protection."""
    ranges: list[tuple[int, int]] = []
    blocks = detect_table_blocks(content)
    lines = content.split('\n')

    char_positions: list[int] = []
    pos = 0
    for line in lines:
        char_positions.append(pos)
        pos += len(line) + 1

    for block in blocks:
        if block.start_line < len(char_positions):
            start_char = char_positions[block.start_line]
            end_idx = min(block.end_line + 1, len(char_positions) - 1)
            end_char = char_positions[end_idx] + len(lines[end_idx])
            ranges.append((start_char, end_char))

    return ranges


def is_inside_table(char_pos: int, table_ranges: list[tuple[int, int]]) -> bool:
    for start, end in table_ranges:
        if start <= char_pos <= end:
            return True
    return False


def _safe_break_position(
    content: str,
    current_start: int,
    target_end: int,
    max_end: int,
    boundaries: list[tuple[int, str, int]],
    table_ranges: list[tuple[int, int]],
    min_chars: int,
) -> int:
    """Find the best safe break position: at a section boundary, not inside table.

    If no boundary found within [target_end, max_end], break at first
    blank-line pair after target_end that is not inside a table.
    If still nothing, break at max_end.
    """
    content_len = len(content)

    # Candidate 1: section boundaries between min_chars and max_end
    best: int | None = None
    for pos, _title, _level in boundaries:
        if current_start + min_chars <= pos <= max_end:
            if not is_inside_table(pos, table_ranges):
                if best is None or abs(pos - target_end) < abs(best - target_end):
                    best = pos
    if best is not None:
        return best

    # Candidate 2: double-newline after target_end, outside table
    search_start = max(target_end - 200, current_start + min_chars)
    idx = search_start
    while idx < max_end:
        pos = content.find('\n\n', idx)
        if pos == -1 or pos >= max_end:
            break
        pos += 2  # break after the blank line
        if not is_inside_table(pos, table_ranges):
            return pos
        idx = pos + 1

    # Candidate 3: any position after target_end outside table
    for pos in range(target_end, max_end):
        if content[pos] == '\n' and not is_inside_table(pos, table_ranges):
            return pos + 1

    return min(max_end, content_len)


def rechunk_by_structure(
    nodes: list[dict[str, Any]],
    target_chars: int = 8000,
    min_chars: int = 2000,
    max_chars: int = 0,
    overlap_chars: int = 200,
    stats: CleaningStats | None = None,
) -> list[dict[str, Any]]:
    """Rechunk nodes by document structure.

    - Groups by source document.
    - Splits only at safe boundaries (heading, numbered section, blank line pair).
    - NEVER cuts inside a table block.
    - Allows chunk to grow up to max_chars before forced cut.
    - Overlap by paragraph (does not split inside table).
    """
    if max_chars <= 0:
        max_chars = int(target_chars * 1.8)

    if not nodes:
        return []

    # Group by source
    by_source: dict[str, list[dict[str, Any]]] = defaultdict(list)
    for node in nodes:
        source = node.get('source', 'unknown')
        by_source[source].append(node)

    output_chunks: list[dict[str, Any]] = []

    for source, source_nodes in by_source.items():
        source_nodes.sort(key=lambda n: (n.get('page', 0), n.get('chunk_id', '')))

        # --- Merge all content ---
        merged_content = ''
        page_markers: list[tuple[int, int]] = []  # (char_pos, page_num)

        for node in source_nodes:
            page = node.get('page', 0)
            content = node.get('content', '')
            if merged_content:
                merged_content += '\n\n'
            page_markers.append((len(merged_content), page))
            merged_content += content

        if not merged_content.strip():
            continue

        # Clean <!--PAGE:0--> markers – extract real page info
        # Replace page markers with empty (they add noise)
        def _extract_page(m: re.Match[str]) -> str:
            return ''
        # Track page marker positions before removing
        real_page_map: list[tuple[int, int]] = []
        for m in re.finditer(r'<!--PAGE:(\d+)-->', merged_content):
            pnum = int(m.group(1))
            real_page_map.append((m.start(), pnum))
        merged_content = re.sub(r'<!--PAGE:\d+-->\s*', '', merged_content)

        # --- Re-run table repair on merged content ---
        # Tables may span across original node boundaries; repair again
        _merge_stats = CleaningStats()
        # First merge orphaned fragments, then repair tables
        merged_content = merge_orphaned_table_fragments(merged_content, _merge_stats)
        merged_content = repair_all_tables(merged_content, _merge_stats)
        if stats:
            stats.continuation_lines_merged += _merge_stats.continuation_lines_merged
            stats.tables_repaired += _merge_stats.tables_repaired
            stats.separator_rows_fixed += _merge_stats.separator_rows_fixed
        # Clean up excessive newlines from merging
        merged_content = clean_excessive_newlines(merged_content)
        # Deduplicate any repeated content from cross-node merging
        merged_content = deduplicate_consecutive_lines(merged_content)

        # Rebuild page markers relative to cleaned content (approximate)
        # Use source node page info as fallback
        page_at_char: list[tuple[int, int]] = page_markers

        # --- Analysis ---
        boundaries = find_section_boundaries(merged_content)
        table_ranges = find_table_ranges(merged_content)
        content_length = len(merged_content)

        # --- Build chunks ---
        current_start = 0
        chunk_idx = 0

        while current_start < content_length:
            target_end = min(current_start + target_chars, content_length)
            max_end = min(current_start + max_chars, content_length)

            if target_end >= content_length:
                # Last chunk
                break_pos = content_length
            else:
                break_pos = _safe_break_position(
                    merged_content, current_start, target_end, max_end,
                    boundaries, table_ranges, min_chars,
                )

            chunk_content = merged_content[current_start:break_pos].strip()

            if chunk_content:
                # Page range
                chunk_page_start = _page_at(current_start, page_at_char)
                chunk_page_end = _page_at(break_pos - 1, page_at_char)

                # Section path
                section_path = 'Document'
                for pos, title, _level in boundaries:
                    if pos <= current_start:
                        section_path = title[:60]

                chunk_id = f"{Path(source).stem}_chunk_{chunk_idx:04d}"
                has_table = any(
                    s <= break_pos and e >= current_start
                    for s, e in table_ranges
                )

                new_chunk: dict[str, Any] = {
                    'source': source,
                    'page': chunk_page_start if chunk_page_start > 0 else None,
                    'page_start': chunk_page_start if chunk_page_start > 0 else None,
                    'page_end': chunk_page_end if chunk_page_end > 0 else None,
                    'chunk_id': chunk_id,
                    'section_path': section_path,
                    'tags': source_nodes[0].get('tags', []) if source_nodes else [],
                    'content': chunk_content,
                    'metadata': {
                        'char_count': len(chunk_content),
                        'token_count': len(chunk_content.split()),
                        'has_table': has_table,
                    },
                }
                output_chunks.append(new_chunk)
                chunk_idx += 1

            if break_pos <= current_start:
                break_pos = current_start + max_chars
            current_start = break_pos

        if stats:
            stats.output_chunks += chunk_idx

    return output_chunks


def _page_at(char_pos: int, page_markers: list[tuple[int, int]]) -> int:
    """Get page number at character position."""
    page = 1
    for mpos, pnum in page_markers:
        if mpos <= char_pos:
            if pnum > 0:
                page = pnum
        else:
            break
    return page


# =============================================================================
# MAIN PIPELINE
# =============================================================================

def clean_content(content: str, stats: CleaningStats,
                  warnings: list[str] | None = None) -> str:
    """Apply all cleaning operations to content."""
    if warnings is None:
        warnings = []

    # Step 1: Remove image links
    content = remove_image_links(content, stats)

    # Step 2: Remove footer lines
    content = remove_footer_lines(content, stats)

    # Step 3: Remove long separators (> 50 chars of dashes)
    content = remove_long_separators(content, stats)

    # Step 4: Remove spam lines
    content = remove_spam_lines(content, stats)

    # Step 5: Remove gibberish lines
    content = remove_gibberish_lines(content, stats)

    # Step 6: Replace <br> in tables
    content = replace_br_in_tables(content, stats)

    # Step 6b: Merge orphaned table fragments (before state machine)
    content = merge_orphaned_table_fragments(content, stats)

    # Step 7: Repair tables (state machine)
    content = repair_all_tables(content, stats, warnings)

    # Step 8: Normalize headers (## - → ##, blank line before)
    content = normalize_headers(content, stats)

    # Step 9: Normalize bullets (- + → -)
    content = normalize_bullets(content)

    # Step 10: Remove junk separators
    content = remove_junk_separators(content, stats)

    # Step 11: Clean excessive newlines
    content = clean_excessive_newlines(content)

    # Step 12: Deduplicate consecutive duplicate lines
    content = deduplicate_consecutive_lines(content)

    return content


def process_node(
    node: dict[str, Any], stats: CleaningStats
) -> dict[str, Any] | None:
    """Process a single node: classify + clean content.

    Returns None if node is empty after cleaning.
    Adds quality_flags and skip_indexing metadata.
    """
    content = node.get('content', '')
    if not content.strip():
        return None

    # --- Classification ---
    quality_flags: dict[str, Any] = {}
    skip_indexing = False

    if is_administrative(content):
        quality_flags['is_administrative'] = True
        stats.skipped_admin += 1
        skip_indexing = True

    if is_name_list(content):
        quality_flags['is_name_list'] = True
        stats.skipped_name_list += 1
        skip_indexing = True

    if is_toc(content):
        quality_flags['is_toc'] = True
        stats.skipped_toc += 1
        skip_indexing = True

    # --- Cleaning ---
    warnings: list[str] = []
    cleaned_content = clean_content(content, stats, warnings)

    if not cleaned_content.strip():
        return None

    # Check for remaining issues
    if warnings:
        quality_flags['warnings'] = warnings
        quality_flags['needs_manual_table_fix'] = any('HIGH' in w for w in warnings)

    # Build output node
    cleaned_node = node.copy()
    cleaned_node['content'] = cleaned_content
    cleaned_node['quality_flags'] = quality_flags
    if skip_indexing:
        cleaned_node['skip_indexing'] = True

    return cleaned_node


def load_nodes_from_directory(input_dir: Path) -> list[dict[str, Any]]:
    """Load all JSON nodes from a directory."""
    nodes: list[dict[str, Any]] = []
    json_files = sorted(input_dir.glob('*.json'))

    for json_file in json_files:
        if 'temp_' in json_file.name or json_file.name.startswith('.'):
            continue
        try:
            with open(json_file, 'r', encoding='utf-8') as f:
                data = json.load(f)
                if isinstance(data, list):
                    nodes.extend(cast(list[dict[str, Any]], data))
                elif isinstance(data, dict):
                    nodes.append(cast(dict[str, Any], data))
        except Exception as e:
            logger.warning(f"Failed to load {json_file}: {e}")

    return nodes


def save_nodes(nodes: list[dict[str, Any]], output_dir: Path) -> None:
    """Save nodes to output directory (one file per node)."""
    output_dir.mkdir(parents=True, exist_ok=True)
    for i, node in enumerate(nodes):
        chunk_id = node.get('chunk_id', node.get('id', f'node_{i:04d}'))
        output_file = output_dir / f"{chunk_id}.json"
        with open(output_file, 'w', encoding='utf-8') as f:
            json.dump(node, f, ensure_ascii=False, indent=2)


def save_single_json(data: dict[str, Any], output_path: Path) -> None:
    """Save data as a single JSON file."""
    output_path.parent.mkdir(parents=True, exist_ok=True)
    with open(output_path, 'w', encoding='utf-8') as f:
        json.dump(data, f, ensure_ascii=False, indent=2)


def process_single_document(
    doc_data: dict[str, Any],
    stats: PipelineStats,
    temp_dir: Path,
) -> dict[str, Any]:
    """
    Process a single document through the pipeline:
    cleaning_v1 -> final_cleaning -> chunking -> audit
    
    Returns processed data with nodes.
    """
    doc_id = doc_data.get("source_file", "unknown").replace(".pdf", "")
    
    # Skip administrative/TOC content
    content = doc_data.get("content", doc_data.get("cleaned_content", ""))
    if is_administrative(content):
        stats.skipped_admin += 1
        doc_data["skip_indexing"] = True
        doc_data["quality_flags"] = {"is_administrative": True}
    
    if is_toc(content):
        stats.skipped_toc += 1
        doc_data["skip_indexing"] = True
        doc_data["quality_flags"] = doc_data.get("quality_flags", {})
        doc_data["quality_flags"]["is_toc"] = True
    
    # Step 1: Cleaning V1 (if not already cleaned)
    if "cleaned_content" not in doc_data:
        if "content" in doc_data:
            doc_data = clean_marker_output(doc_data)
    
    # Save intermediate to temp
    intermediate_path = temp_dir / "cleaned" / f"{doc_id}_intermediate.json"
    save_single_json(doc_data, intermediate_path)
    
    # Step 2: Final Cleaning (with table placeholder extraction)
    doc_data = final_clean_content(doc_data, extract_tables=True)
    
    # Count tables removed
    tables_removed = doc_data.get("metadata", {}).get("tables_removed", [])
    stats.tables_removed += len(tables_removed)
    
    # Check for high-risk tables
    from pipeline.audit_nodes import HIGH_RISK_KEYWORDS
    for table_info in tables_removed:
        caption = table_info.get("caption", "").lower()
        raw_md = table_info.get("raw_markdown", "").lower()
        combined = f"{caption} {raw_md}"
        for keyword in HIGH_RISK_KEYWORDS:
            if keyword.lower() in combined:
                stats.high_risk_tables += 1
                break
    
    # Save final_cleaned intermediate
    final_cleaned_path = temp_dir / "final_cleaned" / f"{doc_id}_intermediate.json"
    save_single_json(doc_data, final_cleaned_path)
    
    # Step 3: Chunking
    # Use reasonable defaults for chunking (150-400 tokens)
    doc_data = chunk_to_nodes(doc_data, min_tokens=150, max_tokens=400)
    
    # Save chunked intermediate
    chunked_path = temp_dir / "chunked" / f"{doc_id}_chunks.json"
    save_single_json(doc_data, chunked_path)
    
    # Step 4: Audit
    doc_data = audit_and_merge_nodes(doc_data)
    
    # Update stats from audit
    audit_stats = doc_data.get("audit_stats", {})
    stats.noise_detected += audit_stats.get("noise_detected_count", 0)
    stats.duplicates_found += audit_stats.get("duplicate_pairs_found", 0)
    stats.output_nodes += audit_stats.get("final_count", 0)
    
    return doc_data


def run_pipeline(
    input_dir: Path,
    output_dir: Path,
    temp_dir: Path = None,
    do_rechunk: bool = True,
    target_chars: int = 8000,
    max_chars: int = 0,
    dry_run: bool = False,
) -> PipelineStats:
    """
    Run the full pipeline:
    Cleaning V1 -> Final Cleaning (table placeholder) -> Chunking -> Audit -> Export
    
    Output:
    - Final JSON -> output_dir (processed/)
    - Intermediate -> temp_dir (temp_pipeline/)
    - Reports -> temp_dir/reports/
    """
    stats = PipelineStats()
    
    if temp_dir is None:
        temp_dir = Path(input_dir).parent / "temp_pipeline"
    
    # Ensure temp directories exist
    (temp_dir / "cleaned").mkdir(parents=True, exist_ok=True)
    (temp_dir / "final_cleaned").mkdir(parents=True, exist_ok=True)
    (temp_dir / "chunked").mkdir(parents=True, exist_ok=True)
    (temp_dir / "reports").mkdir(parents=True, exist_ok=True)

    # Load nodes
    logger.info(f"Loading nodes from {input_dir}")
    nodes = load_nodes_from_directory(input_dir)
    stats.total_files = len(list(input_dir.glob('*.json')))
    stats.total_input_nodes = len(nodes)

    if not nodes:
        logger.warning("No nodes found to process")
        return stats

    logger.info(f"Loaded {len(nodes)} nodes from {stats.total_files} files")

    # Group nodes by source document
    by_source: dict[str, list[dict[str, Any]]] = defaultdict(list)
    for node in nodes:
        source = node.get('source', node.get('source_file', 'unknown'))
        by_source[source].append(node)
    
    logger.info(f"Found {len(by_source)} source documents")
    
    # Process each document through pipeline
    all_processed: list[dict[str, Any]] = []
    
    for source, source_nodes in by_source.items():
        logger.info(f"Processing: {source}")
        
        # Combine nodes into single document structure
        doc_id = Path(source).stem
        
        # Merge all content from nodes
        merged_content = '\n\n'.join([
            n.get('content', '') for n in source_nodes if n.get('content')
        ])
        
        doc_data = {
            "source_file": source,
            "content": merged_content,
            "metadata": {
                "original_node_count": len(source_nodes)
            }
        }
        
        # Process through pipeline
        processed = process_single_document(doc_data, stats, temp_dir)
        all_processed.append(processed)
        
        # Generate audit report
        generate_audit_report(processed, temp_dir / "reports", doc_id)
    
    # Rechunk if enabled and target_chars specified
    all_output_nodes: list[dict[str, Any]] = []
    
    for processed in all_processed:
        doc_nodes = processed.get("nodes", [])
        
        if do_rechunk and target_chars > 0:
            # Perform additional rechunking by structure
            rechunked = rechunk_by_structure(
                doc_nodes,
                target_chars=target_chars,
                max_chars=max_chars,
                stats=stats,
            )
            all_output_nodes.extend(rechunked)
        else:
            # Convert nodes to output format
            for node in doc_nodes:
                output_node = {
                    "source": processed.get("source_file", "unknown"),
                    "page": node.get("metadata", {}).get("node_index", 0) + 1,
                    "chunk_id": node.get("id", "unknown"),
                    "tags": node.get("metadata", {}).get("tags", []),
                    "content": node.get("content", ""),
                    "metadata": node.get("metadata", {}),
                }
                if "quality_flags" in node:
                    output_node["quality_flags"] = node["quality_flags"]
                all_output_nodes.extend([output_node])
    
    stats.output_chunks = len(all_output_nodes)

    # Save output to processed/ (final output only)
    if not dry_run:
        # Clear any existing files in output_dir to ensure only final output
        output_dir.mkdir(parents=True, exist_ok=True)
        
        logger.info(f"Saving {len(all_output_nodes)} final chunks to {output_dir}")
        save_nodes(all_output_nodes, output_dir)
        
        # Also save combined JSON for each document
        for processed in all_processed:
            doc_id = processed.get("source_file", "unknown").replace(".pdf", "")
            doc_id = re.sub(r'[^\w\-]', '_', doc_id)
            
            # Save final combined output
            final_path = output_dir / f"{doc_id}_final.json"
            save_single_json({
                "source_file": processed.get("source_file"),
                "metadata": processed.get("metadata", {}),
                "audit_stats": processed.get("audit_stats", {}),
                "nodes": processed.get("nodes", []),
            }, final_path)
    else:
        logger.info(
            f"[DRY RUN] Would save {len(all_output_nodes)} chunks to {output_dir}"
        )

    return stats


def print_stats(stats: PipelineStats) -> None:
    """Print pipeline summary."""
    print("\n" + "=" * 60)
    print("PIPELINE SUMMARY")
    print("=" * 60)
    print(f"Input files:              {stats.total_files}")
    print(f"Input nodes:              {stats.total_input_nodes}")
    print()
    print("Processing Results:")
    print(f"  Tables removed:         {stats.tables_removed}")
    print(f"  High-risk tables:       {stats.high_risk_tables}")
    print(f"  Headers normalized:     {stats.headers_normalized}")
    print(f"  Noise detected:         {stats.noise_detected}")
    print(f"  Duplicates found:       {stats.duplicates_found}")
    print()
    print("Content Classification:")
    print(f"  Skipped admin:          {stats.skipped_admin}")
    print(f"  Skipped TOC:            {stats.skipped_toc}")
    print()
    print(f"Output nodes:             {stats.output_nodes}")
    print(f"Output chunks:            {stats.output_chunks}")
    print("=" * 60)
    print()
    print("IMPORTANT: Tables have been replaced with placeholders")
    print(f"  -> {stats.tables_removed} tables removed from indexing")
    print(f"  -> {stats.high_risk_tables} high-risk tables flagged for review")
    print("=" * 60)


# =============================================================================
# CLI INTERFACE
# =============================================================================

def main():
    parser = argparse.ArgumentParser(
        description="Clean and rechunk medical PDF nodes for RAG/KG (v3)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Pipeline: Cleaning V1 -> Final Cleaning -> Chunking -> Audit -> Export

Output Directories:
  - processed/        : Final JSON output only
  - temp_pipeline/    : Intermediate files and reports

Examples:
    python scripts/clean_and_rechunk.py data/processed/
    python scripts/clean_and_rechunk.py data/processed/ --output data/processed/
    python scripts/clean_and_rechunk.py data/processed/ --target-chars 8000
    python scripts/clean_and_rechunk.py data/processed/ --no-rechunk
    python scripts/clean_and_rechunk.py data/processed/ --dry-run
        """,
    )

    parser.add_argument(
        'input_dir', type=Path,
        help='Input directory containing JSON node files',
    )
    parser.add_argument(
        '--output', '-o', type=Path, default=None,
        help='Output directory for final JSON (default: data/processed/)',
    )
    parser.add_argument(
        '--temp-dir', type=Path, default=None,
        help='Directory for intermediate files (default: temp_pipeline/)',
    )
    parser.add_argument(
        '--target-chars', type=int, default=8000,
        help='Target characters per chunk (default: 8000)',
    )
    parser.add_argument(
        '--max-chars', type=int, default=0,
        help='Maximum characters per chunk before forced break (default: 1.8x target)',
    )
    parser.add_argument(
        '--no-rechunk', action='store_true',
        help='Skip rechunking (only clean and audit)',
    )
    parser.add_argument(
        '--dry-run', action='store_true',
        help='Preview without writing files',
    )

    args = parser.parse_args()

    if not args.input_dir.exists():
        print(f"Error: Input directory not found: {args.input_dir}")
        return 1

    # Default output to data/processed/
    if args.output is None:
        args.output = args.input_dir.parent / "processed"
        if args.input_dir.name == "processed":
            # If input is already processed, output to same location
            args.output = args.input_dir
    
    # Default temp dir
    if args.temp_dir is None:
        args.temp_dir = args.input_dir.parent / "temp_pipeline"

    logger.info(f"Input:  {args.input_dir}")
    logger.info(f"Output: {args.output}")
    logger.info(f"Temp:   {args.temp_dir}")
    logger.info(f"Target chars: {args.target_chars}")

    stats = run_pipeline(
        input_dir=args.input_dir,
        output_dir=args.output,
        temp_dir=args.temp_dir,
        do_rechunk=not args.no_rechunk,
        target_chars=args.target_chars,
        max_chars=args.max_chars,
        dry_run=args.dry_run,
    )

    print_stats(stats)
    return 0


if __name__ == '__main__':
    exit(main())
